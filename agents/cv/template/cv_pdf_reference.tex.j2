\newcommand{\sidebartitle}[1]{{\color{accent}\fontsize{6.8}{7.2}\selectfont\bfseries\MakeUppercase{#1}\par}\vspace{0.4mm}{\color{rulefg}\rule{\linewidth}{0.25pt}\par}\vspace{0.8mm}}
