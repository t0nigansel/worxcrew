\newcommand{\sidebartitle}[1]{{\color{accent}\fontsize{7.0}{7.4}\selectfont\bfseries\MakeUppercase{#1}\par}\vspace{0.3mm}{\color{rulefg}\rule{\linewidth}{0.25pt}\par}\vspace{1.1mm}}
