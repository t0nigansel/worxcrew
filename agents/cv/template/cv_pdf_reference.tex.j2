\newenvironment{sidebaritemize}{\fontsize{5.55}{7.7}\selectfont\begin{itemize}\setlength{\leftmargin}{1.4mm}\setlength{\itemsep}{0.8mm}\setlength{\topsep}{0pt}\setlength{\parsep}{0pt}\setlength{\parskip}{0pt}\setlength{\partopsep}{0pt}}{\end{itemize}}
\newenvironment{detailitemize}{\fontsize{5.75}{7.7}\selectfont\begin{itemize}\setlength{\leftmargin}{2.4mm}\setlength{\itemsep}{0.55mm}\setlength{\topsep}{0.75mm}\setlength{\parsep}{0pt}\setlength{\parskip}{0pt}\setlength{\partopsep}{0pt}}{\end{itemize}}
\newlength{\sidebarwidth}
\setlength{\sidebarwidth}{48mm}
\newlength{\gutterwidth}
