\newenvironment{tightitemize}{\fontsize{7.5}{8.4}\selectfont\begin{itemize}\setlength{\leftmargin}{2.4mm}\setlength{\itemsep}{0.2mm}\setlength{\topsep}{0.2mm}\setlength{\parsep}{0pt}\setlength{\parskip}{0pt}\setlength{\partopsep}{0pt}}{\end{itemize}}
\newlength{\sidebarwidth}
