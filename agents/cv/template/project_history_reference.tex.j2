% ── Macros ──────────────────────────────────────────────────
\newcommand{\phname}[1]{{\fontsize{16}{17}\selectfont\bfseries #1\par}}
\newcommand{\phheadline}[1]{{\color{accent}\fontsize{8.6}{9.2}\selectfont\bfseries #1\par}}
\newcommand{\phmetaline}[1]{{\color{mutedfg}\fontsize{7}{8}\selectfont #1\par}}
\newcommand{\phdoctitle}[1]{{\color{accent}\fontsize{9}{10}\selectfont\bfseries\MakeUppercase{#1}\par}}
\newcommand{\phprojectname}[1]{{\fontsize{8.5}{9.2}\selectfont\bfseries #1}}
\newcommand{\phperiod}[1]{{\color{accent}\fontsize{6.5}{7}\selectfont\bfseries\MakeUppercase{#1}}}
\newcommand{\phprojectmeta}[1]{{\color{mutedfg}\fontsize{7}{8}\selectfont #1\par}}
\newcommand{\phcontext}[1]{\vspace{0.8mm}{\setlength{\fboxsep}{1.5mm}\colorbox{surface}{\parbox{\dimexpr\linewidth-2\fboxsep-2pt\relax}{\color{mutedfg}\fontsize{7}{8.2}\selectfont #1}}}\par\vspace{0.8mm}}
\newcommand{\phresptitle}[1]{{\fontsize{7.5}{8.4}\selectfont\bfseries #1\par}}
\newcommand{\phrespdesc}[1]{{\color{mutedfg}\fontsize{7}{8.2}\selectfont #1\par}}
\newcommand{\phtoolline}[1]{{\color{accent}\fontsize{6.8}{7.6}\selectfont\bfseries #1\par}}

[% macro project_badge(tone, label) -%]
[% if label %]
[% if tone == "badge-security" %]
{\setlength{\fboxsep}{1.2pt}\colorbox{badgedark}{\textcolor{white}{\fontsize{5.5}{6.0}\selectfont\bfseries [[ label | latex_escape ]]}}}
[% elif tone == "badge-automation" %]
{\setlength{\fboxsep}{1.2pt}\colorbox{badgegreen}{\textcolor{white}{\fontsize{5.5}{6.0}\selectfont\bfseries [[ label | latex_escape ]]}}}
[% elif tone == "badge-ai" %]
{\setlength{\fboxsep}{1.2pt}\colorbox{badgeblue}{\textcolor{white}{\fontsize{5.5}{6.0}\selectfont\bfseries [[ label | latex_escape ]]}}}
[% else %]
{\setlength{\fboxsep}{1.2pt}\colorbox{badgeslate}{\textcolor{white}{\fontsize{5.5}{6.0}\selectfont\bfseries [[ label | latex_escape ]]}}}
[% endif %]
[% endif %]
[% endmacro -%]

\begin{document}
\sloppy

% ── Header ──────────────────────────────────────────────────
\noindent
\begin{minipage}[t]{0.65\textwidth}
\vspace*{0pt}
\phname{[[ content.full_name | latex_escape ]]}
\phheadline{[[ content.headline | latex_escape ]]}
\vspace{0.5mm}
\phmetaline{[[ content.contact_line | latex_escape ]]}
{\color{accentstrong}\fontsize{6.8}{7.6}\selectfont
[% for item in content.links %]
\href{[[ item["url"] ]]}{[[ item["label"] | latex_escape ]]}[% if not loop.last %] \textbar{} [% endif %]
[% endfor %]
\par}
\end{minipage}
\hfill
\begin{minipage}[t]{0.3\textwidth}
\vspace*{0pt}
\raggedleft
\phdoctitle{Projekthistorie}
{\color{mutedfg}\fontsize{7}{8}\selectfont [[ content.project_count ]] Projekte\par}
\end{minipage}

\vspace{2mm}
{\color{accent}\rule{\linewidth}{0.6pt}\par}
\vspace{3mm}

% ── Projects ────────────────────────────────────────────────
[% for project in content.projects %]

% Project heading
\noindent
{\phprojectname{[[ project.name | latex_escape ]]}\hfill\phperiod{[[ project.period | latex_escape ]]}\par}
{\phprojectmeta{[[ [project.client, project.role, project.methodology] | select | join(" | ") | latex_escape ]]}%
\hfill [[ project_badge(project.badge_tone, project.badge_label) ]]\par}

[% if project.system_purpose %]
\phcontext{[[ project.system_purpose | latex_escape ]]}
[% endif %]

[% if project.responsibilities %]
\vspace{0.5mm}
[% for resp in project.responsibilities %]
\phresptitle{[[ resp.title | latex_escape ]]}
[% if resp.description %]
\phrespdesc{[[ resp.description | latex_escape ]]}
[% endif %]
\vspace{0.8mm}
[% endfor %]
[% endif %]

[% if project.tools_line %]
\phtoolline{[[ project.tools_line | latex_escape ]]}
[% endif %]

\vspace{1.5mm}
[% if not loop.last %]
{\color{rulefg}\rule{\linewidth}{0.25pt}\par}
\vspace{2.5mm}
[% endif %]

[% endfor %]

\end{document}
